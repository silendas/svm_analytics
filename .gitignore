# Ignore everything
*

# But not these files...
!.gitignore
!README.md
!app.py
!requirements.txt
!templates/
!templates/index.html

# Ignore all files in templates except index.html
templates/*
!templates/index.html

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
env/

# IDE settings
.idea/
.vscode/

# Environment variables
.env

# Log files
*.log

# System files
.DS_Store
Thumbs.db

# Distribution / packaging
dist/
build/
*.egg-info/

# Testing
.coverage
.pytest_cache/

# Data files
*.csv
*.xlsx